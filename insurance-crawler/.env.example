# ─── Browser ───────────────────────────────────────────────────────────────────
# Set to "true" to run headless (no visible browser window)
HEADLESS=false

# ─── Concurrency ───────────────────────────────────────────────────────────────
# Max parallel article fetches per brand query (recommended: 2–4)
ARTICLE_CONCURRENCY=3

# ─── Timeouts (milliseconds) ───────────────────────────────────────────────────
# How long to wait for a page to load before giving up
PAGE_TIMEOUT=30000

# ─── Delays (milliseconds) ─────────────────────────────────────────────────────
# Random delay range between Google searches
SEARCH_DELAY_MIN=3000
SEARCH_DELAY_MAX=6000

# Random delay range between article fetches
ARTICLE_DELAY_MIN=500
ARTICLE_DELAY_MAX=1500

# How long to pause when a CAPTCHA is detected
CAPTCHA_PAUSE_MS=30000

# ─── Output ────────────────────────────────────────────────────────────────────
# Directory for output CSV files (relative to project root)
OUTPUT_DIR=output
